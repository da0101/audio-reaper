#!/bin/bash
# reap — smart audio downloader, routes YouTube and SoundCloud URLs automatically
#
# Usage:
#   reap <url>                       single URL
#   reap <url1> <url2> ...           mixed list of YouTube + SoundCloud URLs
#   reap "search query"              search YouTube and download
#   reap urls.txt                    text file, one URL per line
#   reap --output ~/Music/beats      set download folder (persists)
#   reap --format flac               set format (mp3/m4a/wav/flac)

set -euo pipefail

CONFIG_DIR="${HOME}/.config/audio-reaper"
CONFIG_FILE="${CONFIG_DIR}/output_dir"
DEFAULT_DIR="${HOME}/Downloads"

# Read persisted output dir or fall back to default
OUT_DIR="$DEFAULT_DIR"
[[ -f "$CONFIG_FILE" ]] && OUT_DIR="$(cat "$CONFIG_FILE")"

FMT="mp3"
URLS=()
SEARCH_QUERIES=()

# Refine a search query using Gemini AI (optional, needs GEMINI_API_KEY)
gemini_refine() {
  local query="$1"
  [[ -z "${GEMINI_API_KEY:-}" ]] && { echo "$query"; return; }

  local body
  body=$(python3 -c "
import json, sys
prompt = 'The user wants to find a song. Their query: \"' + sys.argv[1] + '\"\\nReturn ONLY the artist name and song title in the format: Artist - Song Title\\nNo explanation, no quotes, just the artist and title.'
print(json.dumps({'contents': [{'parts': [{'text': prompt}]}]}))
" "$query" 2>/dev/null) || { echo "$query"; return; }

  local response
  response=$(curl -sf --max-time 10 \
    "https://generativelanguage.googleapis.com/v1beta/models/gemini-2.0-flash:generateContent?key=${GEMINI_API_KEY}" \
    -H "Content-Type: application/json" \
    -d "$body" 2>/dev/null) || { echo "$query"; return; }

  local refined
  refined=$(python3 -c "
import json, sys
data = json.loads(sys.argv[1])
print(data['candidates'][0]['content']['parts'][0]['text'].strip())
" "$response" 2>/dev/null) || { echo "$query"; return; }

  [[ -n "$refined" ]] && echo "$refined" || echo "$query"
}

while [[ $# -gt 0 ]]; do
  case "$1" in
    --format|-F)  FMT="$2"; shift 2 ;;
    --output|-o)
      OUT_DIR="$2"
      mkdir -p "$CONFIG_DIR"
      echo "$OUT_DIR" > "$CONFIG_FILE"
      shift 2 ;;
    -*)           echo "Unknown option: $1"; exit 1 ;;
    *)
      if [[ -f "$1" ]]; then
        while IFS= read -r line; do
          [[ -z "$line" || "$line" == \#* ]] && continue
          URLS+=("$line")
        done < "$1"
      elif [[ "$1" == http* ]]; then
        URLS+=("$1")
      else
        SEARCH_QUERIES+=("$1")
      fi
      shift ;;
  esac
done

if [[ ${#URLS[@]} -eq 0 && ${#SEARCH_QUERIES[@]} -eq 0 ]]; then
  echo "Usage: reap <url|query> [--format mp3|m4a|wav|flac] [--output ~/path]"
  echo "       reap \"michael jackson thriller\"   search and download"
  echo "       reap urls.txt"
  echo "       reap-reset              reset output folder to ~/Downloads"
  echo
  echo "  Current output: ${OUT_DIR}"
  exit 1
fi

# Process search queries
for query in "${SEARCH_QUERIES[@]}"; do
  refined=$(gemini_refine "$query")
  if [[ "$refined" != "$query" ]]; then
    echo "  Search: \"$query\" -> \"$refined\""
  else
    echo "  Search: \"$query\""
  fi
  URLS+=("ytsearch1:${refined}")
done

# Route URLs by source
YT_URLS=()
SC_URLS=()
OTHER_URLS=()

for url in "${URLS[@]}"; do
  if [[ "$url" =~ youtube\.com|youtu\.be|^ytsearch ]]; then
    YT_URLS+=("$url")
  elif [[ "$url" =~ soundcloud\.com ]]; then
    SC_URLS+=("$url")
  else
    OTHER_URLS+=("$url")
  fi
done

echo "  Found ${#URLS[@]} URL(s): ${#YT_URLS[@]} YouTube, ${#SC_URLS[@]} SoundCloud, ${#OTHER_URLS[@]} other"
echo "  Format: ${FMT}  |  Output: ${OUT_DIR}"
echo

mkdir -p "$OUT_DIR"

# Download YouTube — 320 kbps
if [[ ${#YT_URLS[@]} -gt 0 ]]; then
  echo "  [YouTube] Downloading ${#YT_URLS[@]} track(s) at 320 kbps..."
  yt-dlp \
    --extract-audio \
    --audio-format "$FMT" \
    --audio-quality 320K \
    --embed-thumbnail \
    --embed-metadata \
    --output "${OUT_DIR}/%(title)s.%(ext)s" \
    --progress \
    "${YT_URLS[@]}"
  echo
fi

# Download SoundCloud — best available
if [[ ${#SC_URLS[@]} -gt 0 ]]; then
  echo "  [SoundCloud] Downloading ${#SC_URLS[@]} track(s) at best available quality..."
  yt-dlp \
    --extract-audio \
    --audio-format "$FMT" \
    --audio-quality 0 \
    --embed-thumbnail \
    --embed-metadata \
    --output "${OUT_DIR}/%(uploader)s - %(title)s.%(ext)s" \
    --progress \
    "${SC_URLS[@]}"
  echo
fi

# Download anything else — best available
if [[ ${#OTHER_URLS[@]} -gt 0 ]]; then
  echo "  [Other] Downloading ${#OTHER_URLS[@]} track(s)..."
  yt-dlp \
    --extract-audio \
    --audio-format "$FMT" \
    --audio-quality 0 \
    --embed-thumbnail \
    --embed-metadata \
    --output "${OUT_DIR}/%(uploader)s - %(title)s.%(ext)s" \
    --progress \
    "${OTHER_URLS[@]}"
  echo
fi

echo "  Done. Saved to ${OUT_DIR}"
